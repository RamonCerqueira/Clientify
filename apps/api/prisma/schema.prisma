generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  BASIC
  PRO
  PREMIUM
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  plan      Plan     @default(BASIC)
  createdAt DateTime @default(now())
  users     User[]
  pages     Page[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  password  String
  tenantId  String   @db.Uuid
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("users")
}

model Page {
  id           String   @id @default(uuid()) @db.Uuid
  title        String
  description  String
  businessType String
  whatsapp     String
  slug         String   @unique
  tenantId     String   @db.Uuid
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads        Lead[]

  @@index([tenantId])
  @@map("pages")
}

model Lead {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  phone     String
  message   String
  pageId    String   @db.Uuid
  createdAt DateTime @default(now())
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@map("leads")
}
